[all:vars]
ansible_ssh_common_args='-o StrictHostKeyChecking=no'

[master_nodes]
master-open5gs ansible_ssh_host=192.168.57.2 ansible_ssh_port=22 ansible_user=vagrant ansible_ssh_private_key_file=.vagrant/machines/master-open5gs/libvirt/private_key node_ip=192.168.57.2

[worker_nodes]
worker-open5gs-01 ansible_ssh_host=192.168.57.3 ansible_ssh_port=22 ansible_user=vagrant ansible_ssh_private_key_file=.vagrant/machines/worker-open5gs-01/libvirt/private_key node_ip=192.168.57.3
worker-open5gs-02 ansible_ssh_host=192.168.57.4 ansible_ssh_port=22 ansible_user=vagrant ansible_ssh_private_key_file=.vagrant/machines/worker-open5gs-02/libvirt/private_key node_ip=192.168.57.4
